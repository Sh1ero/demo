1. Импорт образов из Additional.iso
Сначала смонтируйте ISO и импортируйте образы:

bash
# Монтируем ISO
mkdir /mnt/iso
mount -o loop /path/to/Additional.iso /mnt/iso

# Импортируем образы
docker load -i /mnt/iso/docker/site_latest.tar
docker load -i /mnt/iso/docker/mariadb_latest.tar

# Проверяем
docker images | grep -E "site_latest|mariadb_latest"
Если файлы .tar — используйте docker load. Если директория с образами — возможно, docker import.

2. Файл docker-compose.yml
yaml
version: '3.8'

services:
  testapp:
    image: site_latest
    container_name: tespapp   # по условию testapp → tespapp (оставляем как в задании)
    ports:
      - "8080:80"
    environment:
      - DB_HOST=db
      - DB_NAME=testdb
      - DB_USER=test
      - DB_PASSWORD=P@ssw0rd
    depends_on:
      - db
    restart: unless-stopped

  db:
    image: mariadb_latest
    container_name: db
    environment:
      - MYSQL_ROOT_PASSWORD=rootpass   # можно задать
      - MYSQL_DATABASE=testdb
      - MYSQL_USER=test
      - MYSQL_PASSWORD=P@ssw0rd
    volumes:
      - db_data:/var/lib/mysql
    restart: unless-stopped

volumes:
  db_data:
Примечание: если приложению нужны другие параметры (например DB_PORT, DB_DRIVER) — добавьте в environment для testapp.

